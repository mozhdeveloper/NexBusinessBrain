# NexBusinessBrain – Environment Variables
# Copy this file to .env.local for local development
# Set these in Vercel Dashboard → Project → Settings → Environment Variables

# ─── Backend API ─────────────────────────────────────────────────────────────
# URL of the NexVision RAG backend (FastAPI / Python service)
# Only used when VITE_USE_SIMULATION=false
VITE_API_BASE_URL=https://your-backend-url.com

# ─── Simulation mode ─────────────────────────────────────────────────────────
# true  = fully local simulation, no backend needed (default for Vercel demo)
# false = real HTTP calls to VITE_API_BASE_URL
VITE_USE_SIMULATION=true

# ─── App Meta ────────────────────────────────────────────────────────────────
VITE_APP_NAME=NexBusinessBrain
VITE_APP_VERSION=0.1.0

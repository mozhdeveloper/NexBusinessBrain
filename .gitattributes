# Force LF line endings for all text files — prevents Windows CRLF issues on Vercel
* text=auto eol=lf

# Explicitly enforce LF for Python/config files
*.py text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff2 binary
*.woff binary

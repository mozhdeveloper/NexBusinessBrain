# --- Qwen via Alibaba DashScope (OpenAI-compatible) ---
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# International endpoint (use https://dashscope.aliyuncs.com/compatible-mode/v1 for China region)
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_LLM_MODEL=qwen-max
QWEN_EMBED_MODEL=text-embedding-v3
QWEN_EMBED_DIM=1024

# --- Pinecone ---
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=nexvision-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- LlamaParse (for PDF / DOCX parsing) ---
LLAMA_CLOUD_API_KEY=llx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: LangSmith tracing ---
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=nexvision-rag

# --- Server ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
